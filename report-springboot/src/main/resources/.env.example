# ========================================
#  钉钉 / 宜搭 敏感配置（模板）
#  复制此文件为 .env 并填入真实值
#  .env 已加入 .gitignore，不会提交到仓库
# ========================================

# 钉钉企业内部应用凭证（用于获取 accessToken）
dingtalk.app.key=your-app-key-here
dingtalk.app.secret=your-app-secret-here

# 宜搭生产系统配置
yida.production.app.type=your-app-type
yida.production.system.token=your-system-token
yida.production.user.id=your-user-id
