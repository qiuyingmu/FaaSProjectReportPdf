# ========================================
#  钉钉 / 宜搭 敏感配置（模板）
#  复制此文件为 .env 并填入真实值
#  .env 已加入 .gitignore，不会提交到仓库
# ========================================

# 钉钉企业内部应用凭证（用于获取 accessToken）
dingtalk.app.key=your-app-key-here
dingtalk.app.secret=your-app-secret-here

# 宜搭生产系统配置
yida.production.app.type=your-app-type
yida.production.system.token=your-system-token
yida.production.user.id=your-user-id

# 华为 OBS 配置（用于上传 PDF 报告，不配置则跳过上传仅本地保留）
# 也可以在 IDE 运行配置中添加环境变量或 -D 参数：
#   Environment variables: OBS_ACCESS_KEY=xxx;OBS_SECRET_KEY=xxx
#   或 VM options: -DOBS_ACCESS_KEY=xxx -DOBS_SECRET_KEY=xxx
# OBS_ACCESS_KEY=your-access-key
# OBS_SECRET_KEY=your-secret-key
# OBS_BUCKET_NAME=gzjgjlzx-digitization-business-pdf
