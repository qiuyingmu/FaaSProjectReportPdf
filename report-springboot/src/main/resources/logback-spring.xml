<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 控制台输出（使用系统默认编码，Windows 下为 GBK → 终端正常显示中文） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出（UTF-8 编码，日志文件通用、跨平台正常阅读） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/report.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/report.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!--  日志级别控制                              -->
    <!-- ======================================== -->

    <!-- 抑制第三方库的 DEBUG 日志 -->
    <logger name="com.obs.services" level="WARN"/>
    <logger name="com.obs.log" level="WARN"/>
    <logger name="org.apache.pdfbox" level="WARN"/>
    <logger name="org.apache.fontbox" level="WARN"/>
    <logger name="com.openhtmltopdf" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>

    <!-- 本项目日志 -->
    <logger name="com.alibaba.work.faas" level="INFO"/>

    <!-- 全局默认级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
