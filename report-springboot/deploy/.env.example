# ============================================================
#  FaaSProjectReportPdf 生产环境 .env（部署时使用）
#  将此文件放在 docker-compose.yml 同级目录
# ============================================================

# ---- 管理员密码（必填） ----
# 部署后请立即修改！默认 dev 密码 admin123 不可用于生产
REPORT_ADMIN_PASSWORD=your-strong-password-here

# ---- 生产数据库（可选） ----
# 默认使用 H2 嵌入式数据库（零配置），数据持久化在 ./data 目录
# 如果流量大建议改用 PostgreSQL，取消下方注释并启动 postgres 容器
# DB_URL=jdbc:postgresql://db:5432/report?useSSL=false
# DB_USERNAME=report
# DB_PASSWORD=report123

# ---- CORS -- 前端域名（必填） ----
# 多个域名用逗号分隔（不含末尾斜杠）
CORS_ALLOWED_ORIGINS=https://realtimevideo.jgjl.cn

# ---- Session 超时（可选） ----
# 默认 30 分钟
SESSION_TIMEOUT=30m

# ---- 钉钉 / 宜搭 凭证（复制自 .env.example） ----
dingtalk.app.key=your-app-key-here
dingtalk.app.secret=your-app-secret-here
yida.production.app.type=your-app-type
yida.production.system.token=your-system-token
yida.production.user.id=your-user-id
